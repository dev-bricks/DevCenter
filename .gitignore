# =============================================================================
# .gitignore Template fuer Software Entwicklung Projekte
# Kopieren und als .gitignore im Projektroot ablegen
# Projektspezifische Eintraege am Ende anfuegen
# =============================================================================

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
.eggs/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# ---- Virtuelle Umgebungen ----
venv/
.venv/
env/
.env/

# ---- BACH Interne Steuerungsdateien (NIEMALS in Git!) ----
AUFGABEN.txt
TEST.txt
TESTS.txt
TESTERGEBNISSE.txt
BUGREPORT.md
DIAGNOSE_REPORT.md
SKILL.md

# ---- Persoenliche / Sensible Daten ----
_USER/
.env
.env.*
*.env
credentials.json
client_secret*.json
token.json
*.pem
*.key
keyring/
secrets/
secret/
*.secret
*.secrets
*.db
*.sqlite
*.sqlite3
*.db-wal
*.db-shm

# ---- Build-Artefakte & Releases ----
releases/
*.exe
*.msi
*.msix
*.appx
*.spec
logs/
*.log
*.tmp
*.bak
*.orig

# ---- IDE & Editoren ----
.claude/
.vscode/
.idea/
*.swp
*.swo
*~

# ---- Betriebssystem ----
desktop.ini
Thumbs.db
.DS_Store
ehthumbs.db

# ---- Lokale Sync-/Host-Nebenstaende ----
*-ASUS-GEI.md

# ---- Standard-Patterns ----
PLAN.txt
_archive/
_private/

# ---- Projektspezifisch (hier eigene Eintraege anfuegen) ----
